{
    "manifest_version": 3,
    "name": "KnowNow",
    "version": "1.0",
    "description": "Highlight text and get an instant AI overview",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "host_permissions": [
        "https://api.groq.com/*"
    ]
}